# Server
HOST=0.0.0.0
PORT=8000

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PostgreSQL (user accounts & logs)
DATABASE_URL=postgresql://user:password@localhost:5432/deepfake_db

# MongoDB (detection results, history)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=deepfake_detection

# Security
MAX_FILE_SIZE_MB=100
AUTO_DELETE_AFTER_HOURS=24
RATE_LIMIT_PER_MINUTE=30

# ML (optional: paths to fine-tuned weights)
IMAGE_MODEL_PATH=
VIDEO_MODEL_PATH=
AUDIO_MODEL_PATH=
